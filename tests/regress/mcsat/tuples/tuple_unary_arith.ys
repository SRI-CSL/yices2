;; Regression for the tuple-blast dispatch over the unary arithmetic
;; kinds the iterative driver previously missed: ARITH_IS_INT_ATOM,
;; ARITH_FLOOR, ARITH_ABS. Each assertion forces the kind to appear
;; directly above a (select x i) of an arith-typed tuple component.
;; Without the dispatch entry the term would be classified tuple-free,
;; the un-blasted SELECT would reach old preprocessing, and the solver
;; would error out with "formula not supported".
;;
;; ARITH_CEIL also got the same dispatch fix, but mcsat's nra plugin
;; cannot currently solve any (= (ceil x) k) constraint -- even on a
;; bare real -- so we cannot exercise it end-to-end. The dispatch
;; entry for ARITH_CEIL is reviewed against ARITH_FLOOR's, which is
;; structurally identical.

(define-type T (tuple int real))

(define x::T)

;; ARITH_FLOOR / ARITH_IS_INT_ATOM over a real tuple component.
(assert (= (select x 2) (/ 7 2)))
(assert (not (is-int (select x 2))))
(assert (= (floor (select x 2)) 3))

;; ARITH_ABS over an int tuple component.
(assert (>= (select x 1) 5))
(assert (= (abs (- (select x 1))) (select x 1)))

(check)
